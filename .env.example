# Backend API base URL — used by the public app for read-only data fetches.
# Local dev: http://localhost:4000 (default). Production: your deployed back.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Auth0 (SPA) — public values, but kept out of source so per-environment configs
# are easy. Get these from your Auth0 application settings.
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-client-id
# Optional — only set when calling a protected API.
NEXT_PUBLIC_AUTH0_AUDIENCE=

# Google Maps — used by @vis.gl/react-google-maps in the browser.
# Restrict this key in Google Cloud Console (HTTP referrer + Maps JS only).
NEXT_PUBLIC_MAPS_API_KEY=
NEXT_PUBLIC_MAP_ID=

# Google Maps Geocoding — used by the prototype geocoder (server-side only).
# Restrict to Geocoding API + IP allow-list in Google Cloud Console.
GOOGLE_MAPS_GEOCODING_KEY=
